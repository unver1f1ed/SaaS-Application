<UserControl x:Class="SaaS_PR.Views.Shared.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:user="clr-namespace:SaaS_PR.ViewModels.Shared"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=user:ProfileViewModel}"
             Background="{StaticResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Обліковий запис"
                       Style="{StaticResource PageTitle}" />
            <TextBlock Text="Керуйте вашою особистою інформацією та паролем"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"
                       Margin="0 0 0 32" />

            <!-- Profile info card -->
            <materialDesign:Card Style="{StaticResource Card}" Margin="0 0 0 24">
                <StackPanel>

                    <TextBlock Text="ОСОБИСТА ІНФОРМАЦІЯ"
                               Style="{StaticResource SectionLabel}"
                               Margin="0 0 0 16" />

                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Ім'я"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}" />
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Прізвище"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}" />
                    </Grid>

                    <TextBox materialDesign:HintAssist.Hint="Електронна адреса"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 24" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 0 0 8" />

                    <TextBlock Text="{Binding SuccessMessage}"
                               Style="{StaticResource SuccessText}"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 0 0 8" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateProfileCommand}"
                            Content="ЗБЕРЕГТИ ЗМІНИ"
                            HorizontalAlignment="Center" />

                </StackPanel>
            </materialDesign:Card>

            <!-- Change password card -->
            <materialDesign:Card Style="{StaticResource Card}">
                <StackPanel>

                    <TextBlock Text="ЗМІНИТИ ПАРОЛЬ"
                               Style="{StaticResource SectionLabel}"
                               Margin="0 0 0 16" />

                    <PasswordBox materialDesign:HintAssist.Hint="Поточний пароль"
                                 materialDesign:PasswordBoxAssist.Password="{Binding CurrentPassword, Mode=TwoWay}"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 16" />

                    <PasswordBox materialDesign:HintAssist.Hint="Новий пароль"
                                 materialDesign:PasswordBoxAssist.Password="{Binding NewPassword, Mode=TwoWay}"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 16" />

                    <PasswordBox materialDesign:HintAssist.Hint="Підтвердити новий пароль"
                                 materialDesign:PasswordBoxAssist.Password="{Binding ConfirmNewPassword, Mode=TwoWay}"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 24" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding ChangePasswordCommand}"
                            Content="ЗМІНИТИ ПАРОЛЬ"
                            HorizontalAlignment="Center" />

                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>

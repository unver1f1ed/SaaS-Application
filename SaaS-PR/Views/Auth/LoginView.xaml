<UserControl x:Class="SaaS_PR.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:auth="clr-namespace:SaaS_PR.ViewModels.Auth"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=auth:LoginViewModel, IsDesignTimeCreated=True}"
             Background="{StaticResource AppBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left decorative panel -->
            <ColumnDefinition Width="2*" />
            <!-- Right login form -->
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel — branding -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48">
                <materialDesign:PackIcon Kind="CloudOutline"
                                         Width="56" Height="56"
                                         Foreground="{StaticResource AccentColor}"
                                         Margin="0 0 0 24"
                                         HorizontalAlignment="Center"/>
                <TextBlock Text="SaaS Система"
                           FontSize="28"
                           FontWeight="Light"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Обліку та керування підписками"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0 8 0 0" />
            </StackPanel>
        </Border>

        <!-- Right panel — login form -->
        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0"
                                  Style="{StaticResource Card}"
                                  Width="380">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="Вітаю!"
                               FontSize="22"
                               FontWeight="Light"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 4" />
                    <TextBlock Text="Ввійдіть у ваш обліковий запис"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0 0 0 28" />

                    <!-- Email -->
                    <TextBox materialDesign:HintAssist.Hint="Електронна адреса"
                             materialDesign:HintAssist.Foreground="{StaticResource TextSecondary}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 16" />

                    <!-- Password -->
                    <PasswordBox materialDesign:HintAssist.Hint="Пароль"
                                 materialDesign:HintAssist.Foreground="{StaticResource TextSecondary}"
                                 materialDesign:PasswordBoxAssist.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 8" />

                    <!-- Error message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 0 0 16" />

                    <!-- Spacer when no error -->
                    <TextBlock Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisibilityConverter}}"
                               Margin="0 0 0 16" />

                    <!-- Login button -->
                    <Button Content="ВВІЙТИ"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0 0 0 16" />

                    <!-- Loading indicator -->
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Width="24" Height="24" />

                </StackPanel>
            </materialDesign:Card>

            <!-- Register link -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 16 0 0">
                <TextBlock Text="Не маєте облікового запису?"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"
                           VerticalAlignment="Center" />
                <Button Content="Створити зараз"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource AccentColor}"
                        Command="{Binding GoToRegisterCommand}"
                        Padding="6 0"
                        Margin="4 0 0 0" />
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

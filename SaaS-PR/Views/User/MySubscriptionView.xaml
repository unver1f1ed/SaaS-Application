<UserControl x:Class="SaaS_PR.Views.User.MySubscriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:user="clr-namespace:SaaS_PR.ViewModels.User"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=user:MySubscriptionViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Мої підписки"
                           Style="{StaticResource PageTitle}"
                           Margin="0" />
                <TextBlock Text="Керуйте вашим планом та підписками"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LoadCommand}"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Subscription picker -->
        <ComboBox Grid.Row="1"
                  materialDesign:HintAssist.Hint="Обрати підписку"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Subscriptions}"
                  SelectedItem="{Binding SelectedSubscription}"
                  DisplayMemberPath="PlanName"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0 0 0 16" />

        <!-- Detail content -->
        <Grid Grid.Row="2"
              Visibility="{Binding SelectedSubscription, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Addons management -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Active addons -->
                <TextBlock Grid.Row="0"
                           Text="АКТИВНІ ДОДАТКИ"
                           Style="{StaticResource SectionLabel}"
                           Margin="0 0 0 12" />

                <materialDesign:Card Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding ActiveAddons}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0AFFFFFF"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource DividerColor}"
                              Foreground="{StaticResource TextPrimary}"
                              materialDesign:DataGridAssist.CellPadding="16 12"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ДОДАТОК"
                                                Binding="{Binding AddonName}"
                                                Width="*" />
                            <DataGridTextColumn Header="К-СТЬ"
                                                Binding="{Binding Quantity}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="ДОДАНО"
                                                Binding="{Binding AddedDate, StringFormat=dd/MM/yyyy}"
                                                Width="Auto" />
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.RemoveAddonCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Прибрати додаток"
                                                Foreground="{StaticResource ErrorColor}">
                                            <materialDesign:PackIcon Kind="MinusCircleOutline"
                                                                     Width="18" Height="18" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

                <!-- Available addons -->
                <TextBlock Grid.Row="3"
                           Text="ДОСТУПНІ ДОДАТКИ"
                           Style="{StaticResource SectionLabel}"
                           Margin="0 0 0 12" />

                <materialDesign:Card Grid.Row="4" Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding AvailableAddons}"
                              SelectedItem="{Binding SelectedAvailableAddon}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0AFFFFFF"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource DividerColor}"
                              Foreground="{StaticResource TextPrimary}"
                              materialDesign:DataGridAssist.CellPadding="16 12"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ДОДАТОК"
                                                Binding="{Binding AddonName}"
                                                Width="*" />
                            <DataGridTextColumn Header="ЦІНА"
                                                Binding="{Binding UnitPrice, StringFormat={}{0:C}}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="ОПЛАТА"
                                                Binding="{Binding BillingType}"
                                                Width="Auto" />
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.AddAddonCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                ToolTip="Додати цей додаток"
                                                Foreground="{StaticResource AccentColor}">
                                            <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                                     Width="18" Height="18" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </materialDesign:Card>

            </Grid>

            <!-- Cancel subscription panel -->
            <materialDesign:Card Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>

                    <TextBlock Text="Деталі підписки"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 20" />

                    <!-- Info rows -->
                    <StackPanel Margin="0 0 0 6">
                        <TextBlock Text="ПЛАН" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding SelectedSubscription.PlanName}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Margin="0 0 0 6">
                        <TextBlock Text="СТАТУС" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding SelectedSubscription.State}"
                                   Foreground="{StaticResource AccentColor}"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Margin="0 0 0 6">
                        <TextBlock Text="ДАТА ПОЧАТКУ" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding SelectedSubscription.StartDate, StringFormat=dd/MM/yyyy}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Margin="0 0 0 6"
                                Visibility="{Binding SelectedSubscription.TrialEndDate,
                                             Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="ТЕСТ ЗАКІНЧУЄТЬСЯ" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding SelectedSubscription.TrialEndDate, StringFormat=dd/MM/yyyy}"
                                   Foreground="{StaticResource AccentColor}"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Margin="0 0 0 24">
                        <TextBlock Text="АВТО ОПЛАТА" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding SelectedSubscription.AutoRenew}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" />
                    </StackPanel>

                    <Separator Background="{StaticResource DividerColor}" Margin="0 0 0 24" />

                    <TextBlock Text="ПРИЧИНА СКАСУВАННЯ"
                               Style="{StaticResource SectionLabel}" />

                    <TextBox materialDesign:HintAssist.Hint="Необов'язково..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding CancellationReason, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="72"
                             Margin="0 0 0 16" />

                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelSubscriptionCommand}"
                            HorizontalAlignment="Stretch"
                            Foreground="{StaticResource ErrorColor}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cancel" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Відмінити підписку"
                                       Margin="8 0 0 0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 12 0 0" />

                </StackPanel>
            </materialDesign:Card>

        </Grid>

    </Grid>
</UserControl>

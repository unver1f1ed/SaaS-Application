<UserControl x:Class="SaaS_PR.Views.User.MyPaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:user="clr-namespace:SaaS_PR.ViewModels.User"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=user:MyPaymentsViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Мої оплати"
                           Style="{StaticResource PageTitle}"
                           Margin="0" />
                <TextBlock Text="Ваша повна історія оплат"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LoadCommand}"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Subscription picker -->
        <ComboBox Grid.Row="1"
                  materialDesign:HintAssist.Hint="Оберіть підписку щоби оглянути оплати"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Subscriptions}"
                  SelectedItem="{Binding SelectedSubscription}"
                  DisplayMemberPath="PlanName"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0 0 0 16" />

        <!-- Payments list -->
        <materialDesign:Card Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasPayments,
                                         Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="CreditCardOutline"
                                             Width="48" Height="48"
                                             Foreground="{StaticResource TextSecondary}"
                                             HorizontalAlignment="Center"
                                             Margin="0 0 0 12" />
                    <TextBlock Text="Жодних оплат знайдено"
                               FontSize="15"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Оберіть підписку вгорі щоби оглянути її історію оплат"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0 6 0 0" />
                </StackPanel>

                <!-- Payments DataGrid -->
                <DataGrid ItemsSource="{Binding Payments}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12"
                          Visibility="{Binding HasPayments,
                                       Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ДАТА"
                                            Binding="{Binding PaymentDate, StringFormat=dd/MM/yyyy HH:mm}"
                                            Width="*" />
                        <DataGridTextColumn Header="СУМА"
                                            Binding="{Binding Amount, StringFormat={}{0:C}}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ВАЛЮТА"
                                            Binding="{Binding Currency}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="МЕТОД"
                                            Binding="{Binding PaymentMethod}"
                                            Width="Auto" />
                        <DataGridTemplateColumn Header="СТАТУС" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4"
                                            Padding="8 3"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Background" Value="#1A66BB6A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Background" Value="#1AFFA726" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Background" Value="#1AEF5350" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Refunded">
                                                        <Setter Property="Background" Value="#1A4DD0E1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11"
                                                   FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessColor}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="#FFA726" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorColor}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Refunded">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentColor}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Error + loading -->
        <StackPanel Grid.Row="3" Margin="0 12 0 0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

    </Grid>
</UserControl>

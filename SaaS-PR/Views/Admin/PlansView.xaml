<UserControl x:Class="SaaS_PR.Views.Admin.PlansView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:SaaS_PR.ViewModels.Admin"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=admin:PlansViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Плани"
                           Style="{StaticResource PageTitle}"
                           Margin="0" />
                <TextBlock Text="Створюйте і керуйте підписками до планів"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}"
                        Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewPlanCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Новий План" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <TextBox Grid.Row="1"
                 materialDesign:HintAssist.Hint="Пошук за назвою, типом, описом..."
                 materialDesign:HintAssist.Foreground="{StaticResource TextSecondary}"
                 materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Foreground="{StaticResource TextPrimary}"
                 Margin="0 0 0 16" />
        
        <!-- Content: list left, form right -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Plans list -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Plans}"
                          SelectedItem="{Binding SelectedPlan}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="НАЗВА"
                                            Binding="{Binding Name}"
                                            Width="*" />
                        <DataGridTextColumn Header="ТИП"
                                            Binding="{Binding PlanType}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ЦІНА"
                                            Binding="{Binding BasePrice, StringFormat={}{0:C}}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ІНТЕРВАЛ"
                                            Binding="{Binding BillingInterval}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ПРОБНІ ДНІ"
                                            Binding="{Binding TrialDays}"
                                            Width="Auto" />
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            ToolTip="Видалити план"
                                            Foreground="{StaticResource ErrorColor}">
                                        <materialDesign:PackIcon Kind="DeleteOutline"
                                                                 Width="18" Height="18" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Edit form -->
            <materialDesign:Card Grid.Column="2"
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Детіла плану"
                                   FontSize="16"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0 0 0 24" />

                        <TextBox materialDesign:HintAssist.Hint="Назва плану"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 16" />

                        <TextBox materialDesign:HintAssist.Hint="Опис (необов'язково)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0 0 0 16" />

                        <TextBox materialDesign:HintAssist.Hint="Базова ціна"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormBasePrice, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 16" />

                        <ComboBox materialDesign:HintAssist.Hint="Тип плану"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding PlanTypes}"
                                  SelectedItem="{Binding FormPlanType}"
                                  Foreground="{StaticResource TextPrimary}"
                                  Margin="0 0 0 16" />

                        <ComboBox materialDesign:HintAssist.Hint="Валюта"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding Currencies}"
                                  SelectedItem="{Binding FormCurrency}"
                                  Foreground="{StaticResource TextPrimary}"
                                  Margin="0 0 0 16" />

                        <ComboBox materialDesign:HintAssist.Hint="Інтервал оплати"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding BillingIntervals}"
                                  SelectedItem="{Binding FormBillingInterval}"
                                  Foreground="{StaticResource TextPrimary}"
                                  Margin="0 0 0 16" />

                        <TextBox materialDesign:HintAssist.Hint="Пробні дні"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormTrialDays, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 24" />

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource ErrorText}"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                                   Margin="0 0 0 16" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CancelEditCommand}"
                                    Content="ВІДМІНИТИ"
                                    HorizontalAlignment="Stretch" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SaveCommand}"
                                    Content="ЗБЕРЕГТИ"
                                    HorizontalAlignment="Stretch" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="SaaS_PR.Views.Admin.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:SaaS_PR.ViewModels.Admin"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=admin:UsersViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Користувачі" Style="{StaticResource PageTitle}" Margin="0" />
                <TextBlock Text="Керуйте зареєстрованими обліковими записами"
                           Foreground="{StaticResource TextSecondary}" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}"
                        Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewUserCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="Новий користувач" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Search bar -->
        <TextBox Grid.Row="1"
                 materialDesign:HintAssist.Hint="Пошук за іменем чи поштою..."
                 materialDesign:HintAssist.Foreground="{StaticResource TextSecondary}"
                 materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Foreground="{StaticResource TextPrimary}"
                 Margin="0 0 0 16" />

        <!-- Content: list left, form right -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Users DataGrid -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ІМ'Я" Binding="{Binding FirstName}" Width="*" />
                        <DataGridTextColumn Header="ПРІЗВИЩЕ" Binding="{Binding LastName}" Width="*" />
                        <DataGridTextColumn Header="ПОШТА" Binding="{Binding Email}" Width="2*" />
                        <DataGridTextColumn Header="РОЛЬ" Binding="{Binding RoleName}" Width="*" />
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteUserCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            ToolTip="Видалити користувача"
                                            Foreground="{StaticResource ErrorColor}">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Edit / Create form -->
            <materialDesign:Card Grid.Column="2"
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>

                    <TextBlock Text="Деталі користувача"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 24" />

                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Ім'я"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}" />
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Прізвище"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{StaticResource TextPrimary}" />
                    </Grid>

                    <TextBox materialDesign:HintAssist.Hint="Електронна адреса"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 16" />

                    <!-- Password only shown when creating -->
                    <PasswordBox materialDesign:HintAssist.Hint="Пароль (мінімум 8 символів)"
                                 materialDesign:HintAssist.Foreground="{StaticResource TextSecondary}"
                                 materialDesign:PasswordBoxAssist.Password="{Binding FormPassword, Mode=TwoWay}"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0 0 0 16"
                                 Visibility="{Binding SelectedUser,
                                              Converter={StaticResource NotNullToVisibilityConverter}}" />

                    <ComboBox materialDesign:HintAssist.Hint="Роль"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding AvailableRoles}"
                              SelectedItem="{Binding FormRole}"
                              DisplayMemberPath="RoleName"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 24" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 0 0 16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelEditCommand}"
                                Content="ВІДМІНИТИ"
                                HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}"
                                Content="ЗБЕРЕГТИ"
                                HorizontalAlignment="Stretch" />
                    </Grid>

                </StackPanel>
            </materialDesign:Card>

        </Grid>

        <!-- Error + loading -->
        <StackPanel Grid.Row="3" Margin="0 12 0 0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

    </Grid>
</UserControl>

<UserControl x:Class="SaaS_PR.Views.Admin.PlanAddonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:SaaS_PR.ViewModels.Admin"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=admin:PlanAddonsViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Додатки планів"
                           Style="{StaticResource PageTitle}"
                           Margin="0" />
                <TextBlock Text="Керуйте додатками до кожного плану"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadPlansCommand}"
                        Margin="0 0 8 0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewAddonCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Новий додаток" Margin="8 0 0 0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Plan picker -->
        <ComboBox Grid.Row="1"
                  materialDesign:HintAssist.Hint="Оберіть план щоби керувати його додатками"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Plans}"
                  SelectedItem="{Binding SelectedPlan}"
                  DisplayMemberPath="Name"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0 0 0 16" />

        <!-- Addons list + form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Addons list -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Addons}"
                          SelectedItem="{Binding SelectedAddon}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="НАЗВА ДОДАТКУ"
                                            Binding="{Binding AddonName}"
                                            Width="*" />
                        <DataGridTextColumn Header="ЦІНА"
                                            Binding="{Binding UnitPrice, StringFormat={}{0:C}}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ТИП ОПЛАТИ"
                                            Binding="{Binding BillingType}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ВАЛЮТА"
                                            Binding="{Binding Currency}"
                                            Width="Auto" />
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            ToolTip="Видалити додаток"
                                            Foreground="{StaticResource ErrorColor}">
                                        <materialDesign:PackIcon Kind="DeleteOutline"
                                                                 Width="18" Height="18" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Edit form -->
            <materialDesign:Card Grid.Column="2"
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>

                    <TextBlock Text="Деталі додатку"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 24" />

                    <TextBox materialDesign:HintAssist.Hint="Назва додатку"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FormAddonName, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 16" />

                    <TextBox materialDesign:HintAssist.Hint="Опис (необов'язково)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="72"
                             Margin="0 0 0 16" />

                    <TextBox materialDesign:HintAssist.Hint="Ціна за одиницю"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FormUnitPrice, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 16" />

                    <ComboBox materialDesign:HintAssist.Hint="Валюта"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding FormCurrency}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 16" />

                    <ComboBox materialDesign:HintAssist.Hint="Тип сплачування"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding BillingTypes}"
                              SelectedItem="{Binding FormBillingType}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 24" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 0 0 16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelEditCommand}"
                                Content="ВІДМІНИТИ"
                                HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}"
                                Content="ЗБЕРЕГТИ"
                                HorizontalAlignment="Stretch" />
                    </Grid>

                </StackPanel>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>

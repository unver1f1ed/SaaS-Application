<UserControl x:Class="SaaS_PR.Views.Admin.PaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:SaaS_PR.ViewModels.Admin"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=admin:PaymentsViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Оплати" Style="{StaticResource PageTitle}" Margin="0" />
                <TextBlock Text="Переглядайте історію оплат та заносьте нові записи про оплату"
                           Foreground="{StaticResource TextSecondary}" FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LoadUsersCommand}"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- User + Subscription pickers -->
        <ComboBox Grid.Row="1"
                  materialDesign:HintAssist.Hint="Оберіть користувача"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0 0 0 12">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="{Binding FirstName}" />
                        <Run Text="{Binding LastName}" />
                        <Run Text=" — " />
                        <Run Text="{Binding Email}" Foreground="{StaticResource TextSecondary}" />
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <ComboBox Grid.Row="2"
                  materialDesign:HintAssist.Hint="Оберіть підписку"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding Subscriptions}"
                  SelectedItem="{Binding SelectedSubscription}"
                  DisplayMemberPath="PlanName"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0 0 0 16" />

        <!-- Payments list + record form -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Payments DataGrid -->
            <materialDesign:Card Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Payments}"
                          SelectedItem="{Binding SelectedPayment}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ДАТА"
                                            Binding="{Binding PaymentDate, StringFormat=dd/MM/yyyy HH:mm}"
                                            Width="*" />
                        <DataGridTextColumn Header="КІЛЬКІСТЬ"
                                            Binding="{Binding Amount, StringFormat={}{0:C}}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ВАЛЮТА" Binding="{Binding Currency}" Width="Auto" />
                        <DataGridTextColumn Header="МЕТОД" Binding="{Binding PaymentMethod}" Width="Auto" />
                        <DataGridTemplateColumn Header="СТАТУС" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.PaymentStatuses,
                                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding Status, Mode=OneWay}"
                                              materialDesign:HintAssist.Hint="Змінити статус"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              Tag="{Binding}"
                                              SelectionChanged="StatusComboBox_SelectionChanged"
                                              Foreground="{StaticResource TextPrimary}"
                                              Margin="0 4" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Record Payment form -->
            <materialDesign:Card Grid.Column="2"
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding SelectedSubscription, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>

                    <TextBlock Text="Записати оплату"
                               FontSize="16" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 24" />

                    <TextBox materialDesign:HintAssist.Hint="Кількість"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding FormAmount, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             Margin="0 0 0 16" />

                    <ComboBox materialDesign:HintAssist.Hint="Валюта"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding FormCurrency}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 16" />

                    <ComboBox materialDesign:HintAssist.Hint="Метод оплати"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding FormPaymentMethod}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 24" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding RecordPaymentCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CreditCardPlus" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Записати оплату" Margin="8 0 0 0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </materialDesign:Card>

        </Grid>

        <!-- Error + loading -->
        <StackPanel Grid.Row="4" Margin="0 12 0 0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

    </Grid>
</UserControl>

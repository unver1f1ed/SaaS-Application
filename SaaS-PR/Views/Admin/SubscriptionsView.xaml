<UserControl x:Class="SaaS_PR.Views.Admin.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:admin="clr-namespace:SaaS_PR.ViewModels.Admin"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=admin:SubscriptionsViewModel}"
             Background="{StaticResource AppBackground}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Підписки"
                           Style="{StaticResource PageTitle}"
                           Margin="0" />
                <TextBlock Text="Переглядайте та керуйте підписками користувачів"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LoadUsersCommand}"
                    VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Оновити" Margin="8 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- User picker -->
        <Grid Grid.Row="1" Margin="0 0 0 16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <ComboBox materialDesign:HintAssist.Hint="Оберіть користувача щоби переглянути його підписки"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      Foreground="{StaticResource TextPrimary}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding FirstName}" />
                            <Run Text="{Binding LastName}" />
                            <Run Text=" — " />
                            <Run Text="{Binding Email}" Foreground="{StaticResource TextSecondary}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- Content: subscriptions list + action panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Create Subscription Panel -->
            <materialDesign:Card Grid.Column="0" 
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding SelectedUser, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Створити підписку"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 16" />

                    <TextBlock Text="ПЛАН"
                               Style="{StaticResource SectionLabel}" />

                    <ComboBox materialDesign:HintAssist.Hint="Оберіть план"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding Plans}"
                              SelectedItem="{Binding SelectedPlan}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">
                                        <Run Text="{Binding BasePrice, StringFormat={}{0:C}}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding BillingInterval}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="Авто оплата"
                              IsChecked="{Binding AutoRenew}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0 0 0 16" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateSubscriptionCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Створити підписку"
                                       Margin="8 0 0 0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="{StaticResource SuccessColor}"
                               TextWrapping="Wrap"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 12 0 0" />

                </StackPanel>
            </materialDesign:Card>

            <!-- Subscriptions list -->
            <materialDesign:Card Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Subscriptions}"
                          SelectedItem="{Binding SelectedSubscription}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource DividerColor}"
                          Foreground="{StaticResource TextPrimary}"
                          materialDesign:DataGridAssist.CellPadding="16 12"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ПЛАН"
                                            Binding="{Binding PlanName}"
                                            Width="*" />
                        <DataGridTextColumn Header="СТАТУС"
                                            Binding="{Binding State}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="ДАТА ПОЧАТКУ"
                                            Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="КІНЕЦЬ ТЕСТУ"
                                            Binding="{Binding TrialEndDate, StringFormat=dd/MM/yyyy}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="АВТО ОПЛАТА"
                                            Binding="{Binding AutoRenew}"
                                            Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Action panel -->
            <materialDesign:Card Grid.Column="4"
                                  Style="{StaticResource Card}"
                                  Visibility="{Binding SelectedSubscription, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>

                    <TextBlock Text="Дії"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0 0 0 8" />

                    <TextBlock Text="{Binding SelectedSubscription.PlanName}"
                               FontSize="13"
                               Foreground="{StaticResource AccentColor}"
                               Margin="0 0 0 24" />

                    <TextBlock Text="ПРИЧИНА СКАСУВАННЯ"
                               Style="{StaticResource SectionLabel}" />

                    <TextBox materialDesign:HintAssist.Hint="Необов'язкові причини..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding CancellationReason, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{StaticResource TextPrimary}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             Margin="0 0 0 16" />

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding RenewSubscriptionCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0 0 0 8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Поновити підписку"
                                       Margin="8 0 0 0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelSubscriptionCommand}"
                            HorizontalAlignment="Stretch"
                            Foreground="{StaticResource ErrorColor}"
                            Margin="0 0 0 8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cancel" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Відмінити підписку"
                                       Margin="8 0 0 0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeleteSubscriptionCommand}"
                            HorizontalAlignment="Stretch"
                            Foreground="{StaticResource ErrorColor}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"
                                                     VerticalAlignment="Center" />
                            <TextBlock Text="Видалити підписку"
                                       Margin="8 0 0 0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0 16 0 0" />

                </StackPanel>
            </materialDesign:Card>

        </Grid>

        <!-- Loading bar -->
        <ProgressBar Grid.Row="3"
                     Style="{StaticResource MaterialDesignLinearProgressBar}"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0 12 0 0" />

    </Grid>
</UserControl>

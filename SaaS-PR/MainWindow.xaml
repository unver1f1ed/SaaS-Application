<Window x:Class="SaaS_PR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="SaaS Manager"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        TextElement.Foreground="{StaticResource TextPrimary}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid>
        <!-- Single content area — NavigationService.CurrentView drives this -->
        <!-- ViewLocator automatically resolves the correct View for each ViewModel -->
        <ContentControl Content="{Binding CurrentView}"
                        ContentTemplateSelector="{Binding ViewLocator, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Grid>
</Window>